// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Branch {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(255)
  address   String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamp(0) @map("updated_at")

  users         User[]
  conversations Conversation[]
  orders        Order[]
  tickets       Ticket[]
  menus         Menu[]
  tables        Table[]
  staffProfiles StaffProfile[]
  staffs        Staff[]

  @@map("branches")
}

model Staff {
  id         Int      @id @default(autoincrement())
  fullName   String?  @db.VarChar(255) @map("full_name")
  email      String   @unique @db.VarChar(255)
  phone      String?  @db.VarChar(50)
  password   String?  @db.VarChar(255)
  role       String?  @default("staff") @db.VarChar(50)
  branch_id  Int?
  branch     Branch?  @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt  DateTime @updatedAt @db.Timestamp(0) @map("updated_at")

  @@map("staffs")
  @@index([branch_id])
}

model Conversation {
  id          Int      @id @default(autoincrement())
  phone       String?  @db.VarChar(255)
  name        String?  @db.VarChar(255)
  platform    String?  @default("whatsapp") @db.VarChar(50)
  last_viewed DateTime? @db.Timestamp(0)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  branch_id   Int?
  customer_id Int?

  branch           Branch? @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  customer         Customer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  messages         Message[]
  replies          Reply[]
  aiMessages       AiMessage[]
  staffMessages    StaffMessage[]
  aiReplies        AiReply[]
  staffReplies     StaffReply[]
  resolved         Resolved?
  escalations      Escalation?
  refunds          Refund[]
  aiFeedback       AiFeedback[]
  deliveryIssues   DeliveryIssue[]
  orders           Order[]
  

  @@map("conversations")
  @@index([branch_id])
  @@index([customer_id])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(255)
  phone     String?  @db.VarChar(255)
  createdAt DateTime @default(now()) @db.Timestamp(0) @map("created_at")
  updatedAt DateTime @updatedAt @db.Timestamp(0) @map("updated_at")

  conversations Conversation[]

  @@map("customers")
}

model Message {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(50)
  message          String?   @db.Text
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Reply {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(50)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("replies")
}

model AiMessage {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(255)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

model StaffMessage {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(255)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("staff_messages")
}

model AiReply {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(255)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("ai replies")
}

model StaffReply {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(255)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("staff replies")
}

model Resolved {
  id               Int       @id @default(autoincrement())
  conversation_id  Int       @unique
  resolved_at      DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("resolved")
}

model Escalation {
  id               Int       @id @default(autoincrement())
  conversation_id  Int       @unique
  customer_name    String?   @db.VarChar(255)
  escalated_at     DateTime  @default(now()) @db.Timestamp(0)
  claimed_by       String?   @db.VarChar(255)
  claim_time       DateTime? @db.Timestamp(0)
  snoozed_until    DateTime? @db.Timestamp(0)
  alarm_active     Boolean?  @default(true)
  assigned_staff_id Int?
  customer_id      Int?
  branch_id        Int?
  escalation_reason String?  @db.VarChar(255)
  detected_intent  String?   @db.VarChar(255)
  ai_confidence    Float?
  original_message String?   @db.Text
  status           String?   @db.VarChar(50)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("escalations")
}

model Refund {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  customer_name    String?   @db.VarChar(255)
  refunded_at      DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("refunds")
  @@index([conversation_id])
}

model AiFeedback {
  id               Int       @id @default(autoincrement())
  conversation_id  Int?
  message_id       Int?
  user_id          Int?
  rating           Int?
  feedback_text    String?   @db.Text
  correction       String?   @db.Text
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation? @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("ai_feedback")
  @@index([conversation_id])
  @@index([user_id])
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique @db.VarChar(255)
  password    String   @db.VarChar(255)
  name        String   @db.VarChar(255)
  role        String?  @default("agent") @db.VarChar(50)
  disabled    Boolean? @default(false)
  created_at  DateTime @default(now()) @db.Timestamp(0)
  branch_id   Int?

  branch              Branch? @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  settings            Setting?
  avatars             UserAvatar[]
  profile             StaffProfile?
  voiceSessionsCreated VoiceSession[] @relation("VoiceSessionCreator")
  voiceParticipations  VoiceParticipant[] @relation("VoiceParticipantUser")

  @@map("users")
  @@index([branch_id])
}

model Setting {
  id            Int     @id @default(autoincrement())
  user_id       Int     @unique
  displayName   String? @db.VarChar(255)
  email         String? @db.VarChar(255)
  password      String? @db.VarChar(255)
  autoReply     String? @db.VarChar(255)
  chatEnabled   String? @db.VarChar(10)
  msgAlert      Boolean?
  ticketAlert   Boolean?
  soundAlert    Boolean?
  priority      String? @db.VarChar(20)
  autoAssign    String? @db.VarChar(10)
  theme         String? @db.VarChar(20)
  translateEnabled Boolean? @db.Boolean @map("translate_enabled")
  translateLang    String? @db.VarChar(10) @map("translate_lang")
  avatarUrl        String? @db.Text @map("avatar_url")
  autopilotMode    String? @db.VarChar(20) @map("autopilotmode")

  user          User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Order {
  id                 Int       @id @default(autoincrement())
  order_id           String?   @unique @db.VarChar(255)
  customer_name      String?   @db.VarChar(255)
  phone              String?   @db.VarChar(255)
  product            String?   @db.Text
  amount             Decimal?  @db.Decimal(10,2)
  total_amount       Decimal?  @db.Decimal(10,2)
  status             String?   @db.VarChar(50)
  order_date         DateTime? @db.Timestamp(0)
  conversation_id    Int?
  voucher_id         Int?
  voucher_code       String?   @db.VarChar(255)
  discount_type      String?   @db.VarChar(50)
  discount_amount    Decimal?  @db.Decimal(10,2)
  subtotal           Decimal?  @db.Decimal(10,2)
  final_total        Decimal?  @db.Decimal(10,2)
  branch_id          Int?
  conversation       Conversation? @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  voucher            Voucher?  @relation(fields: [voucher_id], references: [id], onDelete: SetNull)
  branch             Branch?   @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  deliveries         Delivery[]

  @@map("orders")
  @@index([conversation_id])
  @@index([voucher_id])
  @@index([branch_id])
}

model Delivery {
  id                  Int       @id @default(autoincrement())
  order_id            Int
  rider_name          String?   @db.VarChar(255)
  vehicle             String?   @db.VarChar(128)
  current_lat         Float?
  current_lng         Float?
  customer_lat        Float?
  customer_lng        Float?
  delivery_status     String?   @db.VarChar(64)
  order_confirmed_time DateTime? @db.Timestamp(0)
  rider_assigned_time   DateTime? @db.Timestamp(0)
  picked_up_time        DateTime? @db.Timestamp(0)
  in_transit_time       DateTime? @db.Timestamp(0)
  arriving_time         DateTime? @db.Timestamp(0)
  delivered_time        DateTime? @db.Timestamp(0)
  created_at           DateTime  @default(now()) @db.Timestamp(0)
  updated_at           DateTime  @default(now()) @db.Timestamp(0)
  order                Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("deliveries")
  @@index([order_id])
}

model Receipt {
  id         Int      @id @default(autoincrement())
  content    String?  @db.Text
  escalated  Boolean? @db.Boolean
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@map("receipts")
}

model Voucher {
  id               Int       @id @default(autoincrement())
  code             String    @unique @db.VarChar(255)
  type             String    @db.VarChar(50)
  value            Decimal   @db.Decimal(10,2)
  minimum_order    Decimal?  @db.Decimal(10,2)
  maximum_discount Decimal?  @db.Decimal(10,2)
  usage_limit      Int?
  used_count       Int       @default(0)
  expires_at       DateTime? @db.Timestamp(0)
  is_active        Boolean   @default(true)
  created_by       Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)
  updated_at       DateTime  @updatedAt @db.Timestamp(0)
  orders           Order[]
  redemptions      VoucherRedemption[]

  @@map("vouchers")
  @@index([code])
  @@index([is_active])
  @@index([expires_at])
}

model VoucherRedemption {
  id               Int      @id @default(autoincrement())
  voucher_id       Int
  voucher_code     String   @db.VarChar(255)
  order_id         String?  @db.VarChar(255)
  discount_type    String   @db.VarChar(50)
  discount_amount  Decimal  @db.Decimal(10,2)
  subtotal         Decimal  @db.Decimal(10,2)
  final_total      Decimal  @db.Decimal(10,2)
  redeemed_at      DateTime @default(now()) @db.Timestamp(0)
  voucher          Voucher  @relation(fields: [voucher_id], references: [id], onDelete: Cascade)

  @@map("voucher_redemptions")
  @@index([voucher_id])
  @@index([order_id])
}

model Ticket {
  id            Int      @id @default(autoincrement())
  ticket_type   String?  @db.VarChar(255)
  subject       String?  @db.VarChar(255)
  customer_name String?  @db.VarChar(255)
  customer_phone String? @db.VarChar(255)
  assignee      String?  @db.VarChar(255)
  priority      String?  @db.VarChar(20)
  status        String?  @db.VarChar(50)
  content       String?  @db.Text
  tags          String?  @db.Text
  attachments   String?  @db.Text
  sla_due       DateTime? @db.Timestamp(0)
  escalated     Boolean? @db.Boolean
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  branch_id     Int?
  branch        Branch?   @relation(fields: [branch_id], references: [id], onDelete: SetNull)
  escalatedTicket EscalatedTicket?

  @@map("tickets")
  @@index([branch_id])
}

model CustomerFeedback {
  id                Int       @id @default(autoincrement())
  token             String    @unique @db.VarChar(128)
  ticket_id         Int
  customer_id       Int?
  branch_id         Int?
  rating            Int?
  comment           String?   @db.Text
  used              Boolean   @default(false)
  created_at        DateTime  @default(now()) @db.Timestamp(0)
  expires_at        DateTime  @db.Timestamp(0)
  used_at           DateTime? @db.Timestamp(0)
  submitted_at      DateTime? @db.Timestamp(0)
  feedback_source   String?   @db.VarChar(100)
  created_by_staff_id Int?

  @@map("customer_feedback")
  @@index([ticket_id])
  @@index([branch_id])
}

model EscalatedTicket {
  id            Int      @id @default(autoincrement())
  ticket_id     Int      @unique
  ticket        Ticket   @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  escalated_at  DateTime @default(now()) @db.Timestamp(0)
  escalated_by  String?  @db.VarChar(255)
  reason        String?  @db.Text
  resolved_at   DateTime? @db.Timestamp(0)

  @@map("escalated_tickets")
}

model Food {
  id         Int      @id @default(autoincrement())
  category   String   @db.VarChar(100)
  key_name   String   @db.VarChar(100)
  name       String   @db.VarChar(255)
  price      Decimal  @db.Decimal(10,2)
  available  Int
  image_url  String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)

  @@map("foods")
  @@unique([category, key_name], name: "uk_category_key")
}

model Menu {
  id         Int      @id @default(autoincrement())
  category   String   @db.VarChar(100)
  key_name   String   @db.VarChar(100)
  name       String   @db.VarChar(255)
  price      Decimal  @db.Decimal(10,2)
  available  Int
  image_url  String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)
  branch_id  Int?
  branch     Branch?  @relation(fields: [branch_id], references: [id], onDelete: SetNull)

  @@map("menu")
  @@unique([category, key_name], name: "uk_category_key")
  @@index([branch_id])
}

model Table {
  id            Int      @id @default(autoincrement())
  number        Int      @unique
  label         String   @db.VarChar(255)
  status        String   @default("vacant") @db.VarChar(50)
  customerName  String?  @db.VarChar(255) @map("customer_name")
  reservedUntil DateTime? @db.Timestamp(0) @map("reserved_until")
  isBooking     Boolean  @default(false) @map("is_booking")
  created_at    DateTime @default(now()) @db.Timestamp(0)
  updated_at    DateTime @updatedAt @db.Timestamp(0)
  branch_id     Int?
  branch        Branch?  @relation(fields: [branch_id], references: [id], onDelete: SetNull)

  @@map("restaurant_tables")
  @@index([branch_id])
}

model WhatsappToken {
  id         Int      @id @default(autoincrement())
  token      String?  @db.Text
  expires_at DateTime?
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@map("whatsapp_tokens")
}

model UserAvatar {
  id         Int      @id @default(autoincrement())
  user_id    Int
  filename   String   @db.VarChar(255)
  url        String   @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_avatars")
  @@index([user_id])
}

enum VoiceSessionType {
  PRIVATE
  CHANNEL
  BROADCAST
}

enum VoiceSessionStatus {
  PENDING
  ACTIVE
  ENDED
  CANCELLED
}

model VoiceChannel {
  id         Int            @id @default(autoincrement())
  name       String         @db.VarChar(255)
  description String?       @db.Text
  createdAt  DateTime       @default(now()) @db.Timestamp(0)
  sessions   VoiceSession[]

  @@map("voice_channels")
}

model VoiceSession {
  id          Int                @id @default(autoincrement())
  type        VoiceSessionType   @default(PRIVATE)
  createdBy   Int?
  startedAt   DateTime?          @db.Timestamp(0)
  endedAt     DateTime?          @db.Timestamp(0)
  status      VoiceSessionStatus @default(PENDING)
  createdAt   DateTime           @default(now()) @db.Timestamp(0)
  channelId   Int?

  participants VoiceParticipant[]
  channel      VoiceChannel?      @relation(fields: [channelId], references: [id])
  creator      User?              @relation("VoiceSessionCreator", fields: [createdBy], references: [id])

  @@map("voice_sessions")
  @@index([channelId])
  @@index([createdBy])
}

model VoiceParticipant {
  id         Int       @id @default(autoincrement())
  sessionId  Int
  userId     Int
  joinedAt   DateTime  @default(now()) @db.Timestamp(0)
  leftAt     DateTime? @db.Timestamp(0)
  muted      Boolean   @default(false)

  voiceSession VoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user         User         @relation("VoiceParticipantUser", fields: [userId], references: [id], onDelete: Cascade)

  @@map("voice_participants")
  @@index([sessionId])
  @@index([userId])
}

model DeliveryIssue {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  customer_name    String?   @db.VarChar(255)
  reported_at      DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("delivery_issues")
  @@index([conversation_id])
}

model Email {
  id            Int       @id @default(autoincrement())
  from          String    @db.VarChar(255)
  fromEmail     String    @db.VarChar(255)
  to            String    @db.VarChar(255)
  subject       String    @db.VarChar(255)
  body          String    @db.Text
  preview       String?   @db.Text
  date          DateTime? @db.Timestamp(0)
  isRead        Boolean   @default(false)
  isImportant   Boolean   @default(false)
  isArchived    Boolean   @default(false)
  isSpam        Boolean   @default(false)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @updatedAt @db.Timestamp(0)

  @@map("emails")
  @@index([fromEmail])
  @@index([to])
  @@index([created_at])
}

model StaffProfile {
  id              Int       @id @default(autoincrement())
  user_id         Int       @unique
  firstName        String?   @db.VarChar(255)
  lastName         String?   @db.VarChar(255)
  email           String?   @db.VarChar(255)
  phone           String?   @db.VarChar(255)
  bio             String?   @db.Text
  country         String?   @db.VarChar(255)
  cityState       String?   @db.VarChar(255)
  postalCode      String?   @db.VarChar(255)
  taxId           String?   @db.VarChar(255)
  avatarUrl       String?   @db.Text
  created_at      DateTime  @default(now()) @db.Timestamp(0)
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamp(0)
  branch_id       Int?

  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  branch          Branch?   @relation(fields: [branch_id], references: [id], onDelete: SetNull)

  @@map("staff_profiles")
  @@index([user_id])
  @@index([branch_id])
}

model DashboardSnapshot {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(64)
  data       Json?
  updated_at DateTime @updatedAt @db.Timestamp(0)

  @@map("dashboard_snapshots")
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now()) @db.Timestamp(0)

  @@map("password_resets")
  @@index([email])
  @@index([token])
}

