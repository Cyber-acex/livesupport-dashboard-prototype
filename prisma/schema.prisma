// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Conversation {
  id          Int      @id @default(autoincrement())
  phone       String?  @db.VarChar(255)
  name        String?  @db.VarChar(255)
  platform    String?  @default("whatsapp") @db.VarChar(50)
  last_viewed DateTime? @db.Timestamp(0)
  created_at  DateTime @default(now()) @db.Timestamp(0)

  messages         Message[]
  replies          Reply[]
  aiMessages       AiMessage[]
  staffMessages    StaffMessage[]
  aiReplies        AiReply[]
  staffReplies     StaffReply[]
  resolved         Resolved?
  escalations      Escalation?
  refunds          Refund[]
  aiFeedback       AiFeedback[]
  deliveryIssues   DeliveryIssue[]
  orders           Order[]
  instagramConversation InstagramConversation?

  @@map("conversations")
}

model Message {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(50)
  message          String?   @db.Text
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Reply {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(50)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("replies")
}

model AiMessage {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(255)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("ai_messages")
}

model StaffMessage {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(255)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("staff_messages")
}

model AiReply {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(255)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("ai replies")
}

model StaffReply {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  sender           String    @db.VarChar(255)
  message          String?   @db.Text
  user_id          Int?
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("staff replies")
}

model Resolved {
  id               Int       @id @default(autoincrement())
  conversation_id  Int       @unique
  resolved_at      DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("resolved")
}

model Escalation {
  id               Int       @id @default(autoincrement())
  conversation_id  Int       @unique
  customer_name    String?   @db.VarChar(255)
  escalated_at     DateTime  @default(now()) @db.Timestamp(0)
  claimed_by       String?   @db.VarChar(255)
  claim_time       DateTime? @db.Timestamp(0)
  snoozed_until    DateTime? @db.Timestamp(0)
  alarm_active     Boolean?  @default(true)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("escalations")
}

model Refund {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  customer_name    String?   @db.VarChar(255)
  refunded_at      DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("refunds")
  @@index([conversation_id])
}

model AiFeedback {
  id               Int       @id @default(autoincrement())
  conversation_id  Int?
  message_id       Int?
  user_id          Int?
  rating           Int?
  feedback_text    String?   @db.Text
  correction       String?   @db.Text
  created_at       DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation? @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("ai_feedback")
  @@index([conversation_id])
  @@index([user_id])
}

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique @db.VarChar(255)
  password    String   @db.VarChar(255)
  name        String   @db.VarChar(255)
  role        String?  @default("agent") @db.VarChar(50)
  disabled    Boolean? @default(false)
  created_at  DateTime @default(now()) @db.Timestamp(0)

  settings    Setting?
  avatars     UserAvatar[]
  profile     StaffProfile?

  @@map("users")
}

model Setting {
  id            Int     @id @default(autoincrement())
  user_id       Int     @unique
  displayName   String? @db.VarChar(255)
  email         String? @db.VarChar(255)
  password      String? @db.VarChar(255)
  autoReply     String? @db.VarChar(255)
  chatEnabled   String? @db.VarChar(10)
  msgAlert      Boolean?
  ticketAlert   Boolean?
  soundAlert    Boolean?
  priority      String? @db.VarChar(20)
  autoAssign    String? @db.VarChar(10)
  theme         String? @db.VarChar(20)
  translateEnabled Boolean? @db.Boolean
  translateLang    String? @db.VarChar(10)
  avatarUrl        String? @db.Text
  autopilotMode    String? @db.VarChar(20)

  user          User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Order {
  id              Int       @id @default(autoincrement())
  order_id        String?   @unique @db.VarChar(255)
  customer_name   String?   @db.VarChar(255)
  phone           String?   @db.VarChar(255)
  product         String?   @db.Text
  amount          Decimal?  @db.Decimal(10,2)
  total_amount    Decimal?  @db.Decimal(10,2)
  status          String?   @db.VarChar(50)
  order_date      DateTime? @db.Timestamp(0)
  conversation_id Int?
  conversation    Conversation? @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  deliveries      Delivery[]

  @@map("orders")
  @@index([conversation_id])
}

model Delivery {
  id                  Int       @id @default(autoincrement())
  order_id            Int
  rider_name          String?   @db.VarChar(255)
  vehicle             String?   @db.VarChar(128)
  current_lat         Float?
  current_lng         Float?
  customer_lat        Float?
  customer_lng        Float?
  delivery_status     String?   @db.VarChar(64)
  order_confirmed_time DateTime? @db.Timestamp(0)
  rider_assigned_time   DateTime? @db.Timestamp(0)
  picked_up_time        DateTime? @db.Timestamp(0)
  in_transit_time       DateTime? @db.Timestamp(0)
  arriving_time         DateTime? @db.Timestamp(0)
  delivered_time        DateTime? @db.Timestamp(0)
  created_at           DateTime  @default(now()) @db.Timestamp(0)
  updated_at           DateTime  @default(now()) @db.Timestamp(0)
  order                Order     @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("deliveries")
  @@index([order_id])
}

model Receipt {
  id         Int      @id @default(autoincrement())
  content    String?  @db.Text
  escalated  Boolean? @db.Boolean
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@map("receipts")
}

model Ticket {
  id            Int      @id @default(autoincrement())
  ticket_type   String?  @db.VarChar(255)
  subject       String?  @db.VarChar(255)
  customer_name String?  @db.VarChar(255)
  customer_phone String? @db.VarChar(255)
  assignee      String?  @db.VarChar(255)
  priority      String?  @db.VarChar(20)
  status        String?  @db.VarChar(50)
  content       String?  @db.Text
  tags          String?  @db.Text
  attachments   String?  @db.Text
  sla_due       DateTime? @db.Timestamp(0)
  escalated     Boolean? @db.Boolean
  created_at    DateTime  @default(now()) @db.Timestamp(0)

  @@map("tickets")
}

model Food {
  id         Int      @id @default(autoincrement())
  category   String   @db.VarChar(100)
  key_name   String   @db.VarChar(100)
  name       String   @db.VarChar(255)
  price      Decimal  @db.Decimal(10,2)
  available  Int
  image_url  String?  @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  updated_at DateTime @default(now()) @db.Timestamp(0)

  @@map("foods")
  @@unique([category, key_name], name: "uk_category_key")
}

model WhatsappToken {
  id         Int      @id @default(autoincrement())
  token      String?  @db.Text
  expires_at DateTime?
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@map("whatsapp_tokens")
}

model InstagramToken {
  id         Int      @id @default(autoincrement())
  token      String?  @db.Text
  expires_at DateTime?
  created_at DateTime @default(now()) @db.Timestamp(0)

  @@map("instagram_tokens")
}

model InstagramConversation {
  id              Int          @id @default(autoincrement())
  conversation_id Int          @unique
  ig_id           String?      @db.VarChar(255)
  ig_username     String?      @db.VarChar(255)
  created_at      DateTime     @default(now()) @db.Timestamp(0)
  conversation    Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("instagram_conversations")
}

model UserAvatar {
  id         Int      @id @default(autoincrement())
  user_id    Int
  filename   String   @db.VarChar(255)
  url        String   @db.Text
  created_at DateTime @default(now()) @db.Timestamp(0)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_avatars")
  @@index([user_id])
}

model DeliveryIssue {
  id               Int       @id @default(autoincrement())
  conversation_id  Int
  customer_name    String?   @db.VarChar(255)
  reported_at      DateTime  @default(now()) @db.Timestamp(0)

  conversation     Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("delivery_issues")
  @@index([conversation_id])
}

model StaffProfile {
  id              Int       @id @default(autoincrement())
  user_id         Int       @unique
  firstName        String?   @db.VarChar(255)
  lastName         String?   @db.VarChar(255)
  email           String?   @db.VarChar(255)
  phone           String?   @db.VarChar(255)
  bio             String?   @db.Text
  country         String?   @db.VarChar(255)
  cityState       String?   @db.VarChar(255)
  postalCode      String?   @db.VarChar(255)
  taxId           String?   @db.VarChar(255)
  avatarUrl       String?   @db.Text
  created_at      DateTime  @default(now()) @db.Timestamp(0)
  updated_at      DateTime  @default(now()) @updatedAt @db.Timestamp(0)

  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("staff_profiles")
  @@index([user_id])
}

model DashboardSnapshot {
  id         Int      @id @default(autoincrement())
  name       String   @unique @db.VarChar(64)
  data       Json?
  updated_at DateTime @updatedAt @db.Timestamp(0)

  @@map("dashboard_snapshots")
}

